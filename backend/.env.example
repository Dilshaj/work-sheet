# Database Configuration (AWS RDS SQL Server)
DB_HOST=your-rds-endpoint.amazonaws.com
DB_PORT=1433
DB_NAME=your_db_name
DB_USER=your_username
DB_PASSWORD=your_password
DRIVER_NAME=ODBC Driver 18 for SQL Server

# JWT Security Settings
# Generate a new secret key for production (e.g. openssl rand -hex 32)
SECRET_KEY=generate_this_securely
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# CORS Configuration
# Include your frontend production domain/IP
ALLOWED_ORIGINS=["http://your-production-domain.com", "http://localhost:5173"]